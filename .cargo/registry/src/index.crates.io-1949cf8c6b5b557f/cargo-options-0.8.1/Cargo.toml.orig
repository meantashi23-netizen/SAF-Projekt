[package]
name = "cargo-options"
version = "0.8.1"
edition = "2024"
description = "Reusable common Cargo command line options"
license = "MIT"
keywords = ["clap", "cargo", "cli"]
readme = "README.md"
repository = "https://github.com/messense/cargo-options"
rust-version = "1.85.0"

# See more keys and their definitions at https://doc.rust-lang.org/cargo/reference/manifest.html

[dependencies]
anstyle = "1.0.14"
clap = { version = "4.6.1", features = ["derive", "env", "wrap_help", "unstable-styles"] }
serde = { version = "1.0.228", features = ["derive"], optional = true }

[dev-dependencies]
trycmd = { version = "1.2.0", features = ["examples"] }

[features]
serde = ["dep:serde"]
